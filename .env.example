MASTODON_BASE_URL=https://your-instance.example
MASTODON_ACCESS_TOKEN=your-admin-token
REDIS_URL=redis://localhost:6379
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_KEY=your-key
OPENAI_MODEL=gpt-4o
# Set to false for OpenAI-compatible APIs without response_format support
OPENAI_JSON_MODE=true
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# Quotes are required because the value contains # (otherwise everything
# after # is treated as a comment and the value becomes empty).
# Note: only honored by legacy custom-integration webhooks. Slack-app
# webhooks (required for the suspend button) ignore channel overrides and
# post to the channel chosen at install time.
SLACK_CHANNEL="#spam-alerts"
# Only required for serve mode (the suspend-button interaction server)
SLACK_SIGNING_SECRET=your-slack-signing-secret
LISTEN_ADDR=127.0.0.1:8990
